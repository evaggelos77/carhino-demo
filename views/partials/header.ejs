<!doctype html>
<html lang="<%= lang === "en" ? "en" : "el" %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body data-lang="<%= lang %>">
<header class="topbar">
  <div class="container topbar-inner">
    <a class="brand" href="<%= withLang('/') %>">
      <img src="/assets/branding/carhino-logo-premium-v2.png" alt="Carhino">
      <div class="brand-copy">
        <strong><%= settings.brandName || 'Carhino Leasing' %></strong>
        <span><%= settings.tagline || 'Where Convenience Meets Class' %></span>
      </div>
    </a>
    <nav class="nav">
      <a href="<%= withLang('/') %>"><%= t('Αρχική', 'Home') %></a>
      <a href="<%= withLang('/offers') %>"><%= t('Προσφορές', 'Offers') %></a>
      <a href="<%= withLang('/#how-it-works') %>"><%= t('Πώς λειτουργεί', 'How it works') %></a>
      <a href="<%= withLang('/#faq') %>">FAQ</a>
      <% if (lang === 'en') { %>
        <a class="lang-chip" href="<%= switchToEl %>">EL</a>
      <% } else { %>
        <a class="lang-chip" href="<%= switchToEn %>">EN</a>
      <% } %>
      <a class="btn btn-red" href="<%= withLang('/offers') %>"><%= t('Δες στόλο', 'View fleet') %></a>
    </nav>
  </div>
</header>
